
# --- Checkpointer ---
# Options: memory (default, no deps), sqlite, postgres
CHECKPOINTER=sqlite

# SQLite database path (used when CHECKPOINTER=sqlite)
DATABASE_URL=outputs/checkpoints.db

# --- LangGraph HITL ---
# Set to true to enable real interrupt() in approval_node (demo only — breaks CI)
LANGGRAPH_INTERRUPT=false

# --- Logging ---
LOG_LEVEL=INFO

